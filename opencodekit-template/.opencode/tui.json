{
  "$schema": "https://opencode.ai/tui.json",
  "keybinds": {
    "command_list": ";",
    "leader": "`",
    "session_child_cycle": "ctrl+alt+right",
    "session_child_cycle_reverse": "ctrl+alt+left",
    "session_compact": "ctrl+k"
  },
  "scroll_speed": 3,
  "scroll_acceleration": {
    "enabled": true
  },
  "diff_style": "auto"
}