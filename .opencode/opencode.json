{
	"$schema": "https://opencode.ai/config.json",
	"agent": {
		"build": {
			"description": "Primary development agent with full codebase access",
			"model": "proxypilot/gpt-5.4-high"
		},
		"compaction": {
			"description": "Session summarizer for context continuity across compactions",
			"model": "ollama/minimax-m2.7:cloud"
		},
		"explore": {
			"description": "Fast codebase search specialist",
			"model": "proxypilot/gpt-5.4-none"
		},
		"general": {
			"description": "General-purpose subagent for fast, well-defined tasks; delegates complexity quickly",
			"model": "proxypilot/gpt-5.4-medium"
		},
		"painter": {
			"description": "Image generation and editing specialist using Gemini 3 Pro Image. Use for creating UI mockups, app icons, hero images, visual assets, and editing/redacting existing images",
			"model": "github-copilot/gemini-3.1-pro-preview"
		},
		"plan": {
			"description": "Primary planning agent for architecture and multi-phase execution",
			"model": "proxypilot/gpt-5.4-xhigh"
		},
		"review": {
			"description": "Code review, debugging, and security audit specialist",
			"model": "proxypilot/gpt-5.4-high"
		},
		"scout": {
			"description": "External research specialist for library docs and patterns",
			"model": "ollama/minimax-m2.7:cloud"
		},
		"vision": {
			"description": "Visual content specialist for multimodal analysis and UI/UX guidance",
			"model": "github-copilot/gemini-3.1-pro-preview"
		},
		"build-omo": {
			"description": "OMO-powered implementation — Hephaestus owns execution, Sisyphus orchestrates parallel work",
			"model": "proxypilot/gpt-5.4-high"
		},
		"plan-omo": {
			"description": "OMO-powered planning — Prometheus interviews, Metis consults, Momus critiques",
			"model": "proxypilot/gpt-5.4-high"
		},
		"review-omo": {
			"description": "OMO-powered code review — Oracle finds bugs, Momus challenges assumptions",
			"model": "proxypilot/gpt-5.3-codex-high"
		},
		"scout-omo": {
			"description": "OMO-powered external research — Librarian retrieves docs, Oracle synthesizes architecture decisions",
			"model": "ollama/minimax-m2.7:cloud"
		},
		"explore-omo": {
			"description": "OMO-powered codebase exploration — Explore fans out, Sisyphus-Junior handles parallel probes",
			"model": "proxypilot/gpt-5.4-none"
		},
		"runner": {
			"description": "Lightweight runner for trivial shell, git, and filesystem operations",
			"model": "proxypilot/gpt-5.4-none"
		}
	},
	"autoupdate": false,
	"compaction": {
		"reserved": 128000
	},
	"formatter": {
		"biome": {
			"command": ["npx", "@biomejs/biome", "check", "--write", "$FILE"],
			"extensions": [".js", ".jsx", ".ts", ".tsx", ".json", ".jsonc"]
		},
		"cargo-fmt": {
			"command": ["cargo", "fmt", "--", "$FILE"],
			"extensions": [".rs"]
		},
		"java-formatter": {
			"command": ["google-java-format", "--replace", "$FILE"],
			"environment": {
				"JAVA_HOME": "{env:JAVA_HOME}"
			},
			"extensions": [".java"]
		},
		"laravel-pint": {
			"command": ["npx", "laravel-pint", "--preset", "psr12", "$FILE"],
			"extensions": [".php"]
		},
		"oxfmt": {
			"command": ["npx", "oxfmt", "--write", "$FILE"],
			"extensions": [
				".js",
				".jsx",
				".ts",
				".tsx",
				".json",
				".jsonc",
				".html",
				".css",
				".scss",
				".sass",
				".md",
				".mdx",
				".yaml",
				".yml"
			]
		}
	},
	"instructions": [
		".opencode/memory/project/user.md",
		".opencode/memory/project/tech-stack.md",
		".opencode/memory/project/project.md"
	],
	"keybinds": {
		"leader": "`",
		"session_parent": "<leader>up"
	},
	"mcp": {
		"gitnexus": {
			"command": ["npx", "-y", "gitnexus@latest", "mcp"],
			"enabled": true,
			"timeout": 60000,
			"type": "local"
		},
		"tilth": {
			"command": ["npx", "-y", "tilth", "--mcp", "--edit"],
			"enabled": true,
			"timeout": 60000,
			"type": "local"
		}
	},
	"snapshot": false,
	"model": "proxypilot/gpt-5.4-high",
	"permission": {
		"bash": {
			"*": "allow",
			"cat *": "allow",
			"git branch *": "allow",
			"git checkout *": "ask",
			"git clean *": "ask",
			"git commit *": "ask",
			"git diff *": "allow",
			"git log *": "allow",
			"git merge *": "ask",
			"git push *": "ask",
			"git rebase *": "ask",
			"git reset *": "ask",
			"git status *": "allow",
			"ls *": "allow",
			"npm *": "allow",
			"npm publish *": "ask",
			"npm run db:push*": "ask",
			"npm run db:reset*": "deny",
			"npx *": "allow",
			"rm *": "deny",
			"rm -rf *": "deny",
			"sudo *": "deny"
		},
		"doom_loop": "ask",
		"edit": "allow",
		"external_directory": "ask",
		"question": "allow",
		"read": {
			"*": "allow",
			"*.env": "deny",
			"*.env.*": "deny",
			"*.env.example": "allow",
			"*.key": "deny",
			"*.pem": "deny",
			"*credentials*": "deny",
			"*password*": "deny",
			"*secret*": "deny",
			"*token*": "deny"
		}
	},
	"plugin": [
		"@tarquinen/opencode-dcp@latest",
		"@franlol/opencode-md-table-formatter@0.0.3",
		"openslimedit@latest",
		"file:///root/.config/opencode/omo"
	],
